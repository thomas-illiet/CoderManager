CODER_MANAGER_APP_NAME=Coder Manager
CODER_MANAGER_DATABASE_URL=postgresql+asyncpg://coder_manager:coder_manager@localhost:5432/coder_manager
CODER_MANAGER_CELERY_BROKER_URL=redis://localhost:6379/0
CODER_MANAGER_CELERY_RESULT_BACKEND=redis://localhost:6379/1
CODER_MANAGER_GLOBAL_WHITELIST=false
CODER_MANAGER_CRYPTO_KEY=replace-with-base64-encoded-32-byte-key
CODER_MANAGER_ARGOCD_URL=https://argocd.example.com
CODER_MANAGER_ARGOCD_TOKEN=replace-with-service-account-token
CODER_MANAGER_ARGOCD_SKIP_SSL_VERIFY=false
CODER_MANAGER_ARGOCD_PROJECT=coder
CODER_MANAGER_ARGOCD_APPLICATION_PREFIX=coder
CODER_MANAGER_ARGOCD_REPOSITORY_URL=https://git.example.com/platform/coder.git
CODER_MANAGER_ARGOCD_REPOSITORY_PATH=charts/coder
CODER_MANAGER_ARGOCD_TARGET_REVISION=main
CODER_MANAGER_ARGOCD_DESTINATION_SERVER=https://kubernetes.default.svc
CODER_MANAGER_DEFAULT_ADMINS=admin1,admin2
