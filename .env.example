CODER_MANAGER_APP_NAME=Coder Manager
CODER_MANAGER_DATABASE_URL=postgresql+asyncpg://coder_manager:coder_manager@localhost:5432/coder_manager
CODER_MANAGER_CELERY_BROKER_URL=redis://localhost:6379/0
CODER_MANAGER_CELERY_RESULT_BACKEND=redis://localhost:6379/1
CODER_MANAGER_CRYPTO_KEY=replace-with-base64-encoded-32-byte-key
CODER_MANAGER_JOB_RETRY_INTERVAL_SECONDS=60
CODER_MANAGER_JOB_STALE_AFTER_SECONDS=300
CODER_MANAGER_INSTANCE_DOMAIN=code-studio
CODER_MANAGER_ARGOCD_URL=https://argocd.example.com
CODER_MANAGER_ARGOCD_TOKEN=replace-with-service-account-token
CODER_MANAGER_ARGOCD_SKIP_SSL_VERIFY=false
CODER_MANAGER_ARGOCD_PROJECT=coder
CODER_MANAGER_ARGOCD_APPLICATION_PREFIX=coder
CODER_MANAGER_ARGOCD_REPOSITORY_URL=https://git.example.com/platform/coder.git
CODER_MANAGER_ARGOCD_REPOSITORY_PATH=charts/coder
CODER_MANAGER_ARGOCD_TARGET_REVISION=main
CODER_MANAGER_ARGOCD_DEVELOPMENT_DESTINATION_NAME=development-cluster
CODER_MANAGER_ARGOCD_STAGING_DESTINATION_NAME=staging-cluster
CODER_MANAGER_ARGOCD_PRODUCTION_DESTINATION_NAME=production-cluster
CODER_MANAGER_CYBERARK_DEVELOPMENT_APP_ID=development-app
CODER_MANAGER_CYBERARK_DEVELOPMENT_CERT_NAME=development-cert
CODER_MANAGER_CYBERARK_DEVELOPMENT_KEY_NAME=development-key
CODER_MANAGER_CYBERARK_DEVELOPMENT_SAFE=development-safe
CODER_MANAGER_CYBERARK_STAGING_APP_ID=staging-app
CODER_MANAGER_CYBERARK_STAGING_CERT_NAME=staging-cert
CODER_MANAGER_CYBERARK_STAGING_KEY_NAME=staging-key
CODER_MANAGER_CYBERARK_STAGING_SAFE=staging-safe
CODER_MANAGER_CYBERARK_PRODUCTION_APP_ID=production-app
CODER_MANAGER_CYBERARK_PRODUCTION_CERT_NAME=production-cert
CODER_MANAGER_CYBERARK_PRODUCTION_KEY_NAME=production-key
CODER_MANAGER_CYBERARK_PRODUCTION_SAFE=production-safe
CODER_MANAGER_DEFAULT_ADMINS=admin1,admin2
